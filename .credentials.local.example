# Copy to .credentials.local and fill with real values (never commit .credentials.local).
# Loaded by credentials_loader.load_credentials_local() — existing env vars are not overwritten.

# Proxmox API (one of the following styles)
# PROXMOX_API_TOKEN=PVEAPIToken=user@pam!tokenid=secret-hex
# PROXMOX_TOKEN_ID=user@pam!tokenid
# PROXMOX_TOKEN_SECRET=secret-hex

# MINDEX / website shared keys when scripts call MINDEX or Cloudflare
# MINDEX_API_KEY=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
