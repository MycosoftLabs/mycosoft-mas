{
  "name": "MYCA Daily Standup",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {"field": "cronExpression", "expression": "0 19 * * 1-5"}
          ]
        }
      },
      "id": "cron-standup",
      "name": "Standup (11 AM PT Mon-Fri)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.0.191:8100/standup-prompt",
        "options": {"timeout": 30000}
      },
      "id": "http-standup",
      "name": "Call Standup Prompt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 200]
    }
  ],
  "connections": {
    "Standup (11 AM PT Mon-Fri)": {"main": [[{"node": "Call Standup Prompt", "type": "main", "index": 0}]]}
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "America/Los_Angeles"
  },
  "tags": [
    {"name": "myca"},
    {"name": "standup"},
    {"name": "role-enforcement"}
  ]
}
