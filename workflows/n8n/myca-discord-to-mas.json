{
  "name": "MYCA - Discord to MAS",
  "nodes": [
    {
      "id": "discord-trigger-node",
      "name": "Discord Trigger",
      "type": "n8n-nodes-base.discordTrigger",
      "typeVersion": 1,
      "position": [50, 100],
      "parameters": {
        "events": ["messageCreate"],
        "filters": {
          "channelId": "",
          "keywords": ["MYCA"]
        }
      }
    },
    {
      "id": "parse-message-node",
      "name": "Parse Discord Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [250, 100],
      "parameters": {
        "values": [
          {
            "name": "message_text",
            "type": "string",
            "value": "={{ $node[\"Discord Trigger\"].json.content }}"
          },
          {
            "name": "user_id",
            "type": "string",
            "value": "={{ $node[\"Discord Trigger\"].json.author.id }}"
          },
          {
            "name": "user_name",
            "type": "string",
            "value": "={{ $node[\"Discord Trigger\"].json.author.username }}"
          },
          {
            "name": "channel_id",
            "type": "string",
            "value": "={{ $node[\"Discord Trigger\"].json.channelId }}"
          },
          {
            "name": "message_id",
            "type": "string",
            "value": "={{ $node[\"Discord Trigger\"].json.id }}"
          },
          {
            "name": "session_id",
            "type": "string",
            "value": "=discord_{{ $node[\"Discord Trigger\"].json.author.id }}_{{ Date.now() }}"
          }
        ]
      }
    },
    {
      "id": "http-post-mas-orchestrator",
      "name": "HTTP POST to MAS Orchestrator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 100],
      "parameters": {
        "url": "http://localhost:8001/voice/orchestrator/chat",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        },
        "bodyType": "json",
        "body": {
          "message": "={{ $node[\"Parse Discord Message\"].json.message_text }}",
          "session_id": "={{ $node[\"Parse Discord Message\"].json.session_id }}",
          "platform": "discord",
          "user_id": "={{ $node[\"Parse Discord Message\"].json.user_id }}",
          "user_name": "={{ $node[\"Parse Discord Message\"].json.user_name }}"
        }
      }
    },
    {
      "id": "format-response-node",
      "name": "Format Response for Discord",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [650, 100],
      "parameters": {
        "language": "javascript",
        "code": "const response = $node[\"HTTP POST to MAS Orchestrator\"].json.response || \"No response received\";\nconst maxLength = 2000;\nconst messages = [];\n\nif (response.length > maxLength) {\n  let current = \"\";\n  const words = response.split(\" \");\n  for (const word of words) {\n    if ((current + word).length > maxLength) {\n      messages.push(current.trim());\n      current = word + \" \";\n    } else {\n      current += word + \" \";\n    }\n  }\n  if (current.trim()) messages.push(current.trim());\n} else {\n  messages.push(response);\n}\n\nreturn {\n  messages: messages,\n  message_count: messages.length\n};"
      }
    },
    {
      "id": "discord-send-message",
      "name": "Discord Send Message",
      "type": "n8n-nodes-base.discord",
      "typeVersion": 1,
      "position": [850, 100],
      "parameters": {
        "resource": "message",
        "action": "create",
        "channelId": "={{ $node[\"Parse Discord Message\"].json.channel_id }}",
        "textInput": "={{ $node[\"Format Response for Discord\"].json.messages[0] }}"
      }
    },
    {
      "id": "send-remaining-messages",
      "name": "Send Remaining Messages",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [850, 250],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "compareOperation": ">"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $node[\"Format Response for Discord\"].json.message_count }}",
              "operator": "gt",
              "rightValue": 1
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "loop-remaining-messages",
      "name": "Loop Remaining Messages",
      "type": "n8n-nodes-base.itemLists",
      "typeVersion": 1,
      "position": [1050, 250],
      "parameters": {
        "mode": "splitOut",
        "jsonOutput": "true",
        "value": "={{ $node[\"Format Response for Discord\"].json.messages.slice(1) }}"
      }
    }
  ],
  "connections": {
    "Discord Trigger": [{"node": ["Parse Discord Message"], "type": "main", "index": [0, 0]}],
    "Parse Discord Message": [{"node": ["HTTP POST to MAS Orchestrator"], "type": "main", "index": [0, 0]}],
    "HTTP POST to MAS Orchestrator": [{"node": ["Format Response for Discord"], "type": "main", "index": [0, 0]}],
    "Format Response for Discord": [
      {"node": ["Discord Send Message"], "type": "main", "index": [0, 0]},
      {"node": ["Send Remaining Messages"], "type": "main", "index": [0, 0]}
    ],
    "Send Remaining Messages": [
      {"node": ["Loop Remaining Messages"], "type": "true", "index": [0, 0]},
      {"node": ["Discord Send Message"], "type": "false", "index": [0, 0]}
    ]
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [{"name": "MYCA"}, {"name": "Discord"}, {"name": "Integration"}]
}
