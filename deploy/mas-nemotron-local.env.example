# Copy snippets into /home/mycosoft/mycosoft/mas/.env on VM 192.168.0.188 (mas-orchestrator EnvironmentFile).
# OpenAI-compatible Nemotron / vLLM / TensorRT-LLM on the same host as MAS — no remote URL required.

# Optional: full override (otherwise local default is http://127.0.0.1:11435)
# NEMOTRON_BASE_URL=http://127.0.0.1:11435

# Port for local default when NEMOTRON_BASE_URL is unset (must match your inference server)
# NEMOTRON_HTTP_PORT=11435

# Bind address if not 127.0.0.1 (e.g. sidecar container hostname)
# NEMOTRON_HOST=127.0.0.1

# Set to 1 only to force Ollama when NEMOTRON_BASE_URL is empty (legacy / debugging)
# NEMOTRON_DISABLE_LOCAL_DEFAULT=0

# Model id as registered by the OpenAI-compatible server
# NEMOTRON_MODEL_CORPORATE=nemotron-super
