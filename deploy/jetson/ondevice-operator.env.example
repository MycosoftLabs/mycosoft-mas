# Copy to /etc/mycosoft/ondevice-operator.env on Jetson16
#
# USB connections to Jetson:
# - MycoBrain (Side A + Side B) connects via USB serial -> typically /dev/ttyUSB0 or /dev/ttyACM0
# - If Side A and Side B expose separate ports, use ttyUSB0 and ttyUSB1
# - SIM board (cellular modem) connects via USB -> typically /dev/ttyUSB2 or /dev/ttyACM1
# Use: ls /dev/tty{USB,ACM}* to discover ports after plugging in devices.

ONDEVICE_SIDE_A_PORT=/dev/ttyUSB0
ONDEVICE_SIDE_B_PORT=/dev/ttyUSB1
# Optional: SIM board (cellular modem) when used for cellular backhaul
# ONDEVICE_SIM_PORT=/dev/ttyUSB2
ONDEVICE_MDP_BAUD=115200
ONDEVICE_AUDIT_LOG=/opt/mycosoft/logs/ondevice_audit.jsonl

# OpenClaw Gateway Control UI + WebSocket (default port 18789)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_API_KEY=
