# Copy to /etc/mycosoft/gateway-router.env on Jetson4

GATEWAY_ID=site-gateway-01
GATEWAY_HOST=192.168.0.201
GATEWAY_PORT=8120
GATEWAY_LOCATION=server-room
GATEWAY_AUDIT_LOG=/opt/mycosoft/logs/gateway_audit.jsonl

MAS_API_URL=http://192.168.0.188:8001
MYCORRHIZAE_API_URL=http://192.168.0.187:8002
MINDEX_API_URL=http://192.168.0.189:8000
TELEMETRY_INGEST_URL=http://192.168.0.187:3000

GATEWAY_MAX_ATTEMPTS=8
GATEWAY_FLUSH_INTERVAL_SECONDS=5

GATEWAY_OPENCLAW_BASE_URL=http://127.0.0.1:8000
GATEWAY_OPENCLAW_API_KEY=
