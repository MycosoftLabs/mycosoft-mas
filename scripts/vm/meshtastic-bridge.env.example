# Copy to /etc/mycosoft/meshtastic-bridge.env on 192.168.0.196 (chmod 600). Do not commit real values.
#
# MQTT — subscribe to local Mosquitto on same host
MESHTASTIC_MQTT_HOST=127.0.0.1
MESHTASTIC_MQTT_PORT=1883
MESHTASTIC_MQTT_TLS=0
MESHTASTIC_MQTT_SUBSCRIBE=msh/#
# If Mosquitto requires auth for clients:
# MESHTASTIC_MQTT_USERNAME=
# MESHTASTIC_MQTT_PASSWORD=

# Upstream data plane (LAN)
MINDEX_API_URL=http://192.168.0.189:8000
REDIS_URL=redis://192.168.0.189:6379/0

# MINDEX internal ingest — use one of HMAC pair OR bearer token per MINDEX config
# MINDEX_INTERNAL_SECRET=
# MINDEX_INTERNAL_SERVICE_NAME=mas-meshtastic-bridge
MINDEX_INTERNAL_TOKEN=

LOG_LEVEL=INFO
