# =============================================================================
# Supabase Operational Backbone — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# See docs/SUPABASE_CREDENTIALS_SETUP_MAR07_2026.md
# =============================================================================

# Supabase (required for ingest, sheet sync, LLM ledger)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# PostgreSQL (optional; Supabase REST is primary)
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# MINDEX database (for PersonaPlex Bridge VoiceSessionStore, MAS integrations)
# MINDEX_DB_PASSWORD=
# Or DATABASE_URL=postgresql://mycosoft:PASSWORD@192.168.0.189:5432/mindex

# Asana (optional; for commitments ingest)
ASANA_API_KEY=
ASANA_WORKSPACE_ID=

# Notion (optional; for customer_vendors, commitments, liabilities, recruitment)
NOTION_API_KEY=
NOTION_DATABASE_COMMITMENTS=
NOTION_DATABASE_VENDORS=
NOTION_DATABASE_LIABILITIES=
NOTION_DATABASE_RECRUITMENT=

# GitHub (optional; for commitments ingest)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Google Sheets (required for master spreadsheet sync)
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# MYCA Nemotron Migration Toggle Layer (Corporate-First)
# =============================================================================
# Global mode: hybrid | nemotron | llama
MYCA_BACKEND_MODE=hybrid

# Per-category mode overrides (optional)
MYCA_BACKEND_MODE_CORPORATE=nemotron
MYCA_BACKEND_MODE_INFRA=hybrid
MYCA_BACKEND_MODE_DEVICE=hybrid
MYCA_BACKEND_MODE_ROUTE=hybrid
MYCA_BACKEND_MODE_NLM=hybrid
MYCA_BACKEND_MODE_CONSCIOUSNESS=hybrid

# Nemotron endpoint and model mappings (OpenAI-compatible)
NEMOTRON_BASE_URL=
NEMOTRON_API_KEY=
NEMOTRON_MODEL_SUPER=nemotron-super
NEMOTRON_MODEL_NANO=nemotron-nano
NEMOTRON_MODEL_CORPORATE=nemotron-super
NEMOTRON_MODEL_INFRA=nemotron-nano
NEMOTRON_MODEL_DEVICE=nemotron-nano
NEMOTRON_MODEL_ROUTE=nemotron-nano
NEMOTRON_MODEL_NLM=nemotron-super
NEMOTRON_MODEL_CONSCIOUSNESS=nemotron-super

# Llama/Ollama fallback (kept active during migration)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
