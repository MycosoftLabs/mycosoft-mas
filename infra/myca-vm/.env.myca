# MYCA Workspace VM Environment Variables
# Copy to /opt/myca/.env and fill in real values

# Database
POSTGRES_PASSWORD=changeme

# n8n
N8N_USER=myca_admin
N8N_PASSWORD=changeme

# MAS integration
MAS_API_URL=http://192.168.0.188:8001
MINDEX_API_URL=http://192.168.0.189:8000
OLLAMA_URL=http://192.168.0.188:11434

# Slack (create bot at api.slack.com)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord (create bot at discord.com/developers)
DISCORD_BOT_TOKEN=

# Notion (create integration at notion.so/my-integrations)
NOTION_TOKEN=

# Google Workspace (service account JSON path)
GOOGLE_SERVICE_ACCOUNT_PATH=/opt/myca/credentials/google/service_account.json

# Asana
ASANA_PAT=

# Signal (phone number for signal-cli)
SIGNAL_PHONE_NUMBER=

# ElevenLabs (voice)
ELEVENLABS_API_KEY=

# Anthropic (for local Claude calls)
ANTHROPIC_API_KEY=
