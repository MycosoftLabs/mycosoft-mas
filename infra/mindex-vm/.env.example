# MINDEX VM Environment Variables
# Created: February 4, 2026

# PostgreSQL
POSTGRES_PASSWORD=REDACTED_DB_PASSWORD

# Integrity Service
INTEGRITY_HMAC_SECRET=mycosoft-mindex-integrity-2026

# PGAdmin (optional)
PGADMIN_PASSWORD=mycosoft2026

# Logging
LOG_LEVEL=INFO

# Optional: external research API keys (ETL pulls these from env)
NCBI_API_KEY=your-ncbi-api-key
CHEMSPIDER_API_KEY=your-chemspider-api-key

# =============================================================================
# MINDEX App Overhaul (May 03, 2026) — matches mindex_api/config.py (env names)
# =============================================================================
MAS_API_URL=http://192.168.0.188:8001
REDIS_URL=redis://mindex-redis:6379/0
