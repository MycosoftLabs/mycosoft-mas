# Copy to .credentials.local (same keys) or source before automation — never commit real values.
# Proxmox VE API (preferred): Datacenter → Permissions → API Tokens
PROXMOX_TOKEN_ID=root@pam!agent_mycosoft
PROXMOX_TOKEN_SECRET=<uuid-secret>
PROXMOX_HOST=192.168.0.202
# Optional comma-separated hosts to try first
# PROXMOX_HOSTS=192.168.0.202,192.168.0.90
# Fallback / SSH: root@pam password (often same family as VM_PASSWORD — use env only)
# PROXMOX202_PASSWORD=<same-as-root-or-separate>
# Explicit VMIDs if discovery misses a guest (comma-separated)
# PVE_PRODUCTION_VMIDS=103,104,105,106
