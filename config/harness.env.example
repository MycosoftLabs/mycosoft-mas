# MYCA Harness — optional copy into MAS `.env` or systemd drop-in (no secrets committed)

# ---------- Router (mounted by default on mas-orchestrator) ----------
# HARNESS_API_DISABLED=1

# ---------- Brain chat integration (memory brain vs harness path) ----------
# BRAIN_CHAT_USE_HARNESS=1

# ---------- MINDEX search-in-LLM (default on) ----------
# HARNESS_GROUND_WITH_MINDEX=1
# HARNESS_MINDEX_SEARCH_TYPES=biological
# HARNESS_MINDEX_TIMEOUT=45

# ---------- Nemotron overrides (optional; else backend_selection MYCA_CORE) ----------
# HARNESS_NEMOTRON_BASE_URL=http://192.168.0.241:11434/v1
# HARNESS_NEMOTRON_MODEL=nemotron-8b-or-similar
# NEMOTRON_API_KEY=

# ---------- PersonaPlex ----------
# PERSONAPLEX_BRIDGE_URL=http://192.168.0.241:8999

# ---------- Paths ----------
# HARNESS_STATIC_ANSWERS_PATH=
# HARNESS_INTENTION_DB_PATH=
