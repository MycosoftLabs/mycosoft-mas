{
  "name": "MYCA - Slack to MAS",
  "nodes": [
    {
      "id": "slack-trigger-node",
      "name": "Slack Event Trigger",
      "type": "n8n-nodes-base.slackTrigger",
      "typeVersion": 1,
      "position": [50, 100],
      "parameters": {
        "events": ["app_mention", "message"],
        "slackEvents": ["app_mention"],
        "channel": "#myca"
      }
    },
    {
      "id": "parse-slack-message-node",
      "name": "Parse Slack Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [250, 100],
      "parameters": {
        "values": [
          {
            "name": "message_text",
            "type": "string",
            "value": "={{ $node[\"Slack Event Trigger\"].json.text }}"
          },
          {
            "name": "user_id",
            "type": "string",
            "value": "={{ $node[\"Slack Event Trigger\"].json.user }}"
          },
          {
            "name": "channel_id",
            "type": "string",
            "value": "={{ $node[\"Slack Event Trigger\"].json.channel }}"
          },
          {
            "name": "thread_ts",
            "type": "string",
            "value": "={{ $node[\"Slack Event Trigger\"].json.thread_ts || $node[\"Slack Event Trigger\"].json.ts }}"
          },
          {
            "name": "session_id",
            "type": "string",
            "value": "=slack_{{ $node[\"Slack Event Trigger\"].json.user }}_{{ Date.now() }}"
          },
          {
            "name": "timestamp",
            "type": "string",
            "value": "={{ $node[\"Slack Event Trigger\"].json.ts }}"
          }
        ]
      }
    },
    {
      "id": "http-post-mas-slack",
      "name": "HTTP POST to MAS Orchestrator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 100],
      "parameters": {
        "url": "http://localhost:8001/voice/orchestrator/chat",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        },
        "bodyType": "json",
        "body": {
          "message": "={{ $node[\"Parse Slack Message\"].json.message_text }}",
          "session_id": "={{ $node[\"Parse Slack Message\"].json.session_id }}",
          "platform": "slack",
          "user_id": "={{ $node[\"Parse Slack Message\"].json.user_id }}",
          "channel_id": "={{ $node[\"Parse Slack Message\"].json.channel_id }}"
        }
      }
    },
    {
      "id": "format-slack-response",
      "name": "Format Slack Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [650, 100],
      "parameters": {
        "values": [
          {
            "name": "response_text",
            "type": "string",
            "value": "={{ $node[\"HTTP POST to MAS Orchestrator\"].json.response || \"No response received\" }}"
          },
          {
            "name": "thread_ts",
            "type": "string",
            "value": "={{ $node[\"Parse Slack Message\"].json.thread_ts }}"
          }
        ]
      }
    },
    {
      "id": "slack-post-message",
      "name": "Slack Post Message",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [850, 100],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": "={{ $node[\"Parse Slack Message\"].json.channel_id }}",
        "text": "={{ $node[\"Format Slack Response\"].json.response_text }}",
        "threadTs": "={{ $node[\"Parse Slack Message\"].json.thread_ts }}"
      }
    }
  ],
  "connections": {
    "Slack Event Trigger": [{"node": ["Parse Slack Message"], "type": "main", "index": [0, 0]}],
    "Parse Slack Message": [{"node": ["HTTP POST to MAS Slack"], "type": "main", "index": [0, 0]}],
    "HTTP POST to MAS Slack": [{"node": ["Format Slack Response"], "type": "main", "index": [0, 0]}],
    "Format Slack Response": [{"node": ["Slack Post Message"], "type": "main", "index": [0, 0]}]
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [{"name": "MYCA"}, {"name": "Slack"}, {"name": "Integration"}]
}
